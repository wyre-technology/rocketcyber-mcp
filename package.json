{
  "name": "@wyre-technology/rocketcyber-mcp",
  "version": "1.1.7",
  "description": "MCP (Model Context Protocol) server for RocketCyber Managed SOC platform",
  "main": "dist/entry.js",
  "bin": {
    "rocketcyber-mcp": "./dist/entry.js"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/entry.js",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "prebuild": "npm run clean",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "rocketcyber",
    "managed-soc",
    "cybersecurity",
    "api",
    "typescript",
    "nodejs"
  ],
  "author": "Aaron Sachs",
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@wyre-technology/node-rocketcyber": "latest",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^26.1.0",
    "semantic-release": "^25.0.5",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
